{
  "manifest_version": 3,
  "name": "PigeonGuard",
  "version": "1.0",
  "description": "Detects phishing signs in URLs",
  "permissions": ["tabs", "scripting", "storage", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/pigeon_outline16x16.png",
    "32": "icons/pigeon_outline32x32.png",
    "48": "icons/pigeon_outline48x48.png",
    "64": "icons/pigeon_outline64x64.png",
    "128": "icons/pigeon_outline128x128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/safety16x16.png",
      "32": "icons/safety32x32.png",
      "48": "icons/safety48x48.png",
      "64": "icons/safety64x64.png",
      "128": "icons/safety128x128.png"
    }
  },
"web_accessible_resources": [
  {
    "resources": ["html/warningPage.html","html/popup.html","css/warningPage.css","css/popup.css", "icons/*"],
    "matches": ["<all_urls>"]
  }
]
}